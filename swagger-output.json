{
  "swagger": "2.0",
  "info": {
    "title": "Students & Courses API",
    "description": "API for managing students and courses with Google OAuth authentication",
    "version": "1.0.0"
  },
  "host": "cse341-students-svsc.onrender.com",
  "schemes": ["https"],
  "basePath": "/",
  "securityDefinitions": {
    "googleOAuth": {
      "type": "oauth2",
      "flow": "implicit",
      "authorizationUrl": "/auth/google",
      "scopes": {}
    }
  },
  "paths": {
    "/students": {
      "get": {
        "summary": "Get all students",
        "security": [{"googleOAuth": []}],
        "responses": {
          "200": {
            "description": "List of students",
            "schema": {
              "type": "array",
              "items": {"$ref": "#/definitions/Student"}
            },
            "examples": {
              "application/json": [
                {"firstName":"John","lastName":"Doe","email":"john@example.com","age":21},
                {"firstName":"Jane","lastName":"Smith","email":"jane@example.com","age":22}
              ]
            }
          }
        }
      },
      "post": {
        "summary": "Create a student",
        "security": [{"googleOAuth": []}],
        "parameters": [{
          "in": "body",
          "name": "body",
          "required": true,
          "schema": {"$ref": "#/definitions/Student"}
        }],
        "responses": {
          "201": {
            "description": "Student created",
            "examples": {
              "application/json": {"firstName":"Alice","lastName":"Brown","email":"alice@example.com","age":20}
            }
          },
          "400": {"description": "Validation error"}
        }
      }
    },
    "/students/{id}": {
      "get": {
        "summary": "Get student by ID",
        "security": [{"googleOAuth": []}],
        "parameters": [{"name":"id","in":"path","required":true,"type":"string"}],
        "responses": {
          "200": {"description":"Student found","schema":{"$ref":"#/definitions/Student"}},
          "404": {"description":"Student not found"}
        }
      },
      "put": {
        "summary": "Update student",
        "security": [{"googleOAuth": []}],
        "parameters": [
          {"name":"id","in":"path","required":true,"type":"string"},
          {"in":"body","name":"body","schema":{"$ref":"#/definitions/Student"}}
        ],
        "responses": {
          "200": {"description":"Student updated","schema":{"$ref":"#/definitions/Student"}},
          "400": {"description":"Validation error"},
          "404": {"description":"Student not found"}
        }
      },
      "delete": {
        "summary": "Delete student",
        "security": [{"googleOAuth": []}],
        "parameters": [{"name":"id","in":"path","required":true,"type":"string"}],
        "responses": {
          "200": {"description":"Student deleted"},
          "404": {"description":"Student not found"}
        }
      }
    },
    "/courses": {
      "get": {
        "summary": "Get all courses",
        "security": [{"googleOAuth": []}],
        "responses": {
          "200": {
            "description": "List of courses",
            "schema": {
              "type": "array",
              "items": {"$ref": "#/definitions/Course"}
            },
            "examples": {
              "application/json": [
                {"name":"Math 101","code":"MTH101","instructor":"Dr. Alan","credits":3},
                {"name":"History 201","code":"HIS201","instructor":"Prof. Maria","credits":4}
              ]
            }
          }
        }
      },
      "post": {
        "summary": "Create a course",
        "security": [{"googleOAuth": []}],
        "parameters": [{
          "in": "body",
          "name": "body",
          "required": true,
          "schema": {"$ref": "#/definitions/Course"}
        }],
        "responses": {
          "201": {
            "description": "Course created",
            "examples": {
              "application/json": {"name":"Physics 101","code":"PHY101","instructor":"Dr. James","credits":3}
            }
          },
          "400": {"description":"Validation error"}
        }
      }
    },
    "/courses/{id}": {
      "get": {
        "summary": "Get course by ID",
        "security": [{"googleOAuth": []}],
        "parameters": [{"name":"id","in":"path","required":true,"type":"string"}],
        "responses": {
          "200": {"description":"Course found","schema":{"$ref":"#/definitions/Course"}},
          "404": {"description":"Course not found"}
        }
      },
      "put": {
        "summary": "Update course",
        "security": [{"googleOAuth": []}],
        "parameters": [
          {"name":"id","in":"path","required":true,"type":"string"},
          {"in":"body","name":"body","schema":{"$ref":"#/definitions/Course"}}
        ],
        "responses": {
          "200": {"description":"Course updated","schema":{"$ref":"#/definitions/Course"}},
          "400": {"description":"Validation error"},
          "404": {"description":"Course not found"}
        }
      },
      "delete": {
        "summary": "Delete course",
        "security": [{"googleOAuth": []}],
        "parameters": [{"name":"id","in":"path","required":true,"type":"string"}],
        "responses": {
          "200": {"description":"Course deleted"},
          "404": {"description":"Course not found"}
        }
      }
    }
  },
  "definitions": {
    "Student": {
      "type": "object",
      "required":["firstName","lastName","email","age"],
      "properties": {
        "firstName":{"type":"string"},
        "lastName":{"type":"string"},
        "email":{"type":"string"},
        "age":{"type":"number"}
      }
    },
    "Course": {
      "type":"object",
      "required":["name","code","instructor","credits"],
      "properties":{
        "name":{"type":"string"},
        "code":{"type":"string"},
        "instructor":{"type":"string"},
        "credits":{"type":"number"}
      }
    }
  }
}