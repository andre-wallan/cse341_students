"securityDefinitions": {
  "googleOAuth": {
    "type": "oauth2",
    "flow": "implicit",
    "authorizationUrl": "/auth/google",
    "scopes": {}
  }
},
"paths": {
  "/students": {
    "get": {
      "summary": "Get all students",
      "security": [{"googleOAuth": []}],
      "responses": { "200": { "description": "List of students" } }
    },
    "post": {
      "summary": "Create a student",
      "security": [{"googleOAuth": []}],
      "parameters": [{ "in": "body", "name": "body", "required": true, "schema": { "$ref": "#/definitions/Student" } }],
      "responses": { "201": { "description": "Student created" } }
    }
  },
  "/students/{id}": {
    "get": { "security": [{"googleOAuth": []}], "parameters": [{"name": "id", "in": "path", "required": true, "type": "string"}], "responses": { "200": {"description":"Student found"} } },
    "put": { "security": [{"googleOAuth": []}], "parameters": [{"name":"id","in":"path","required":true,"type":"string"},{"in":"body","name":"body","schema":{"$ref":"#/definitions/Student"}}], "responses": { "200": {"description":"Student updated"} } },
    "delete": { "security": [{"googleOAuth": []}], "parameters": [{"name":"id","in":"path","required":true,"type":"string"}], "responses": { "200": {"description":"Student deleted"} } }
  },
  "/courses": {
    "get": { "summary": "Get all courses", "security": [{"googleOAuth": []}], "responses": {"200":{"description":"List of courses"}} },
    "post": { "summary": "Create course", "security": [{"googleOAuth": []}], "parameters":[{"in":"body","name":"body","required":true,"schema":{"$ref":"#/definitions/Course"}}], "responses":{"201":{"description":"Course created"}} }
  },
  "/courses/{id}": {
    "get": { "security": [{"googleOAuth": []}], "parameters":[{"name":"id","in":"path","required":true,"type":"string"}], "responses":{"200":{"description":"Course found"}} },
    "put": { "security": [{"googleOAuth": []}], "parameters":[{"name":"id","in":"path","required":true,"type":"string"},{"in":"body","name":"body","schema":{"$ref":"#/definitions/Course"}}], "responses":{"200":{"description":"Course updated"}} },
    "delete": { "security": [{"googleOAuth": []}], "parameters":[{"name":"id","in":"path","required":true,"type":"string"}], "responses":{"200":{"description":"Course deleted"}} }
  }
},
"definitions": {
  "Student": {
    "type": "object",
    "required":["firstName","lastName","email","age"],
    "properties": {
      "firstName":{"type":"string"},
      "lastName":{"type":"string"},
      "email":{"type":"string"},
      "age":{"type":"number"}
    }
  },
  "Course": {
    "type":"object",
    "required":["name","code","instructor","credits"],
    "properties":{
      "name":{"type":"string"},
      "code":{"type":"string"},
      "instructor":{"type":"string"},
      "credits":{"type":"number"}
    }
  }
}